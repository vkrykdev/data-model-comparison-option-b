__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/
~$*.xlsx

# Local environment config & secrets — never commit (use .env.example as the template)
.env
.env.*
!.env.example

# Generated deploy working copies (hold injected, environment-specific IDs / SQL endpoint).
# Tracked sources keep placeholders; render/deploy scripts inject real values from .env.
fabric/models/.deploy_*/
fabric/notebooks/.deploy_*/

# Filled-in eval results (live-demo scoring). The tracked workbook is the BLANK
# template; the filled copy holds actual agent answers/scores and stays local.
eval/MultiSourceAgent_Eval.filled.xlsx

# Power BI per-user local report settings (Microsoft recommends ignoring)
**/.pbi/localSettings.json

# Generated export package (sales/PM deliverable — not source)
.export/
