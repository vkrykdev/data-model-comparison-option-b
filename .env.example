# Fabric Option B — environment configuration (EXAMPLE / template)
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env        # (PowerShell: Copy-Item .env.example .env)
#
# `.env` is git-ignored and must NEVER be committed — it holds environment-specific
# identifiers and (optionally) service-principal credentials.
#
# Scripts that read these values:
#   - fabric/bootstrap.sh
#   - fabric/upload_and_load.sh
#   - fabric/deploy_models.py
#   - fabric/render_notebook.py

# ----- Fabric workspace -----
# Display name of the workspace that hosts the demo.
FABRIC_WORKSPACE_NAME="My Fabric Workspace"
# Workspace GUID.  Get it with:  fab get "<workspace name>.Workspace" -q id
FABRIC_WORKSPACE_ID="00000000-0000-0000-0000-000000000000"

# ----- Capacity (reference only; the workspace is already assigned to it) -----
FABRIC_CAPACITY_NAME="my-capacity"

# ----- Folder path (every Option B item lives in the subfolder) -----
FABRIC_FOLDER_PARENT="data-model-comparison"
FABRIC_FOLDER_SUB="Option B"
# GUID of the subfolder above. Find it via: fab api "workspaces/$FABRIC_WORKSPACE_ID/folders"
FABRIC_OPTB_FOLDER_ID="00000000-0000-0000-0000-000000000000"

# ----- Lakehouse -----
FABRIC_LAKEHOUSE_NAME="lh_supply_demo"
# Lakehouse GUID. Find it via: fab api "workspaces/$FABRIC_WORKSPACE_ID/lakehouses"
FABRIC_LAKEHOUSE_ID="00000000-0000-0000-0000-000000000000"
# SQL analytics endpoint host (Lakehouse > Settings > SQL analytics endpoint > Connection string).
# Used to wire up the Direct Lake semantic models.
FABRIC_SQL_ENDPOINT="<server>.datawarehouse.fabric.microsoft.com"

# ----- Service principal auth (OPTIONAL) -----
# Leave blank to authenticate interactively with `fab auth login` (device code).
# If set, bootstrap.sh logs in non-interactively. Treat FAB_CLIENT_SECRET as a secret.
FAB_CLIENT_ID=""
FAB_CLIENT_SECRET=""
FAB_TENANT_ID=""
